{
  "name": "elbaron-bns-server",
  "version": "1.0.0",
  "description": "Backend server for Elbaron BNS, providing APIs for managing products, user authentication, and other essential functionalities.",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "tsx server.ts",
    "stop": "pm2 stop elbaron-bns-server",
    "restart": "pm2 restart elbaron-bns-server",
    "logs": "pm2 logs elbaron-bns-server",
    "dev": "tsx server.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "author": "Beshoy Nady",
  "license": "ISC",
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.4.0",
    "multer": "^1.4.5-lts.1",
    "path": "^0.12.7",
    "qrcode": "^1.5.3",
    "slugify": "^1.6.8",
    "socket.io": "^4.7.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.9.5",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  }
}
