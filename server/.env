# =========================
# 🌐 Server Configuration
# =========================
PORT=8000
FRONT_END_URL="http://localhost:3000"
NODE_ENV= development

# =========================
# 🍃 MongoDB Configuration
# =========================
# لو مفعّل authentication (يوزر وباسورد)
# MONGODB_URL=mongodb://beshoynady:Beshoy88@127.0.0.1:27017/restaurant?authSource=admin

# لو مش مفعّل authentication (مؤقتًا للتجربة)
MONGODB_URL= mongodb://127.0.0.1:27017/restaurant


SECRET_KEY=beshoynady-secretkey-restaurant
INITIAL_SETUP_KEY=beshoynady-initial-setup-key

# =========================
# 🔐 JWT Configuration
# =========================
ACCESS_TOKEN_SECRET=my_super_access_secret_key

REFRESH_TOKEN_SECRET=my_super_refresh_secret_key

ACCESS_TOKEN_EXPIRES=1d

REFRESH_TOKEN_EXPIRES=7d